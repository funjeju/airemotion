# ── Glide 환경변수 예시 ──
# 실제 값은 .env.local 에 채우세요. .env.local 은 git에 커밋하지 않습니다.
# NEXT_PUBLIC_ 접두어가 붙은 값만 브라우저로 노출됩니다. 시크릿에는 절대 붙이지 마세요.

# Firebase (클라이언트 — 공개돼도 되는 설정값) — Phase 1
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (서버 전용 — 절대 NEXT_PUBLIC_ 금지) — Phase 1
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Whisper(STT, 서버 전용) — Phase 4
OPENAI_API_KEY=

# 렌더 공급자 — local(셀프호스트/로컬, 무료) | lambda(우리 클라우드, 유료)
# 미설정 시 local. 우리 SaaS 배포에서만 lambda로 설정.
GLIDE_RENDER_PROVIDER=local

# 렌더링(Remotion Lambda, 서버 전용) — provider=lambda일 때
REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# 아래 둘은 `npx remotion lambda functions deploy` / `sites create` 후 나오는 값
REMOTION_LAMBDA_FUNCTION_NAME=
# 한도 안 병렬 상한(한도10이면 9). 증설되면 올려 속도↑. REMOTION_FRAMES_PER_LAMBDA로 직접 지정도 가능
REMOTION_MAX_RENDERERS=9
REMOTION_SERVE_URL=
